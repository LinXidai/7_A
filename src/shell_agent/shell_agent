# src/shell_agent.py
import json
import os
import re
from typing import Dict, Any, Literal

from llm_client import LLMClient

# Define the JSON Schema for Shell Agent's output
SHELL_AGENT_OUTPUT_SCHEMA = {
    "type": "object",
    "properties": {
        "intent": {"type": "string", "enum": ["run_command", "ask_clarification", "refuse"]},
        "command": {"type": "string", "description": "The shell command to execute, if intent is run_command"},
        "reason": {"type": "string", "description": "Reasoning for the command or clarification needed"},
        "risk_level": {"type": "string", "enum": ["low", "medium", "high"], "description": "Assessed risk level of the command"},
    },
    "required": ["intent", "reason", "risk_level"],
    "if": {"properties": {"intent": {"const": "run_command"}}},
    "then": {"required": ["command"]},
}

class ShellAgent:
    """
    Shell Agent converts natural language to shell commands and applies safety checks.
    """
    SYSTEM_PROMPT = """
    You are a Shell Agent. Your task is to convert user's natural language requests into safe and executable shell commands.
    You operate within a TUI environment.
    Always output a JSON object according to the following schema:
    {json_schema}

    Here are the definitions for 'intent':
    - 'run_command': You have a clear command to execute.
    - 'ask_clarification': The user's request is ambiguous, and you need more information.
    - 'refuse': The request is impossible, unsafe, or outside your capabilities.

    Here are the definitions for 'risk_level':
    - 'low': The command is generally safe and expected (e.g., 'ls', 'pwd', 'cat safe_file').
    - 'medium': The command has potential side effects but is usually safe if user intent is clear (e.g., 'mv', 'cp', 'mkdir', 'touch').
    - 'high': The command is potentially dangerous or destructive (e.g., 'rm -rf', 'sudo', 'mkfs', 'dd if=', 'chown').

    Current Context:
    - Operating System: {os_info}
    - Current Working Directory: {cwd}
    - Recent Directory Listing (if available): {ls_info}

    If you need to ask for clarification, ensure the 'reason' field explains exactly what information you need and why.
    Do not guess commands if you are unsure. Prioritize safety and clarity.
    """

    # Local rules for high-risk commands (patterns)
    HIGH_RISK_PATTERNS = [
        r'\brm\s+-rf\b', # rm -rf
        r'\bsudo\b',     # sudo
        r'\bmkfs\b',     # mkfs (format disk)
        r'\bdd\s+if=',   # dd if= (disk imaging/wiping)
        r'\bchown\b',    # chown (change ownership)
        r'\bchmod\s+.*777\b', # chmod with full permissions
        r'\b>?\s*/dev/(sda|sdb|sdc|nvme|null|zero)\b', # Redirecting to or from critical device files
        r'\bpasswd\b', # commands related to password changes
        rr'\bcurl\s+-s?f?\s+-o\s+/dev/null\b' # Some common download patterns often used in malicious scripts
        # Add more patterns as needed
    ]

    def __init__(self, llm_client: LLMClient):
        self.llm_client = llm_client

    async def generate_command(self, natural_language_input: str, context: Dict[str, Any]) -> Dict[str, Any]:
        """
        Uses LLM to convert natural language into a structured command proposal.
        """
        os_info = context.get("os_info", "Unknown")
        cwd = context.get("cwd", "/")
        ls_info = context.get("ls_info", "Not available")

        system_prompt = self.SYSTEM_PROMPT.format(
            json_schema=json.dumps(SHELL_AGENT_OUTPUT_SCHEMA, indent=2),
            os_info=os_info,
            cwd=cwd,
            ls_info=ls_info,
        )

        messages = [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": natural_language_input}
        ]

        try:
            response = await self.llm_client.generate_json_response(messages, SHELL_AGENT_OUTPUT_SCHEMA)
            return response
        except (json.JSONDecodeError, ValueError) as e:
            return {
                "intent": "refuse",
                "reason": f"Failed to parse LLM's structured output: {e}. Raw response might be malformed.",
                "risk_level": "high"
            }
        except Exception as e:
            return {
                "intent": "refuse",
                "reason": f"An error occurred during LLM command generation: {e}",
                "risk_level": "high"
            }

    def check_command_safety(self, command: str, llm_risk_level: Literal["low", "medium", "high"]) -> Literal["low", "medium", "high"]:
        """
        Performs local safety checks on the generated command.
        Combines LLM's assessment with local rule engine.
        Returns the final assessed risk level.
        """
        current_risk_level = llm_risk_level

        # Local rule engine for high-risk patterns
        for pattern in self.HIGH_RISK_PATTERNS:
            if re.search(pattern, command, re.IGNORECASE):
                # If a high-risk pattern is matched, override LLM's assessment to 'high'
                # and return immediately as this is critical.
                return "high"

        # If LLM assessed medium or high and no local override, keep it.
        # Otherwise, if LLM says low and no local high-risk, it's low.
        return current_risk_level
